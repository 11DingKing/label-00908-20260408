APP_NAME="Billing System"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Shanghai
APP_URL=http://localhost:8000

APP_LOCALE=zh_CN
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=zh_CN

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=billing_system
DB_USERNAME=root
DB_PASSWORD=root123456
DB_PERSISTENT=false
DB_POOL_MIN=1
DB_POOL_MAX=10
DB_CONNECT_TIMEOUT=10
DB_WAIT_TIMEOUT=3

# 读写分离配置（可选）
# DB_READ_HOST=mysql-read
# DB_READ_PORT=3306
# DB_READ_USERNAME=readonly
# DB_READ_PASSWORD=readonly123

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
CACHE_PREFIX=billing_

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_QUEUE_DB=2

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

JWT_SECRET=
JWT_TTL=60
JWT_REFRESH_TTL=20160

# Alipay 配置（变量名需与 config/payment.php 一致）
ALIPAY_APP_ID=
ALIPAY_PUBLIC_KEY=
ALIPAY_PRIVATE_KEY=
ALIPAY_GATEWAY_URL=https://openapi.alipay.com/gateway.do
ALIPAY_NOTIFY_URL=

# WeChat Pay 配置（变量名需与 config/payment.php 一致）
WECHAT_PAY_APP_ID=
WECHAT_PAY_MCH_ID=
WECHAT_PAY_API_KEY=
WECHAT_PAY_NOTIFY_URL=

# 支付配置
PAYMENT_DEFAULT_GATEWAY=stripe
PAYMENT_DEFAULT_CURRENCY=CNY
PAYMENT_BASE_CURRENCY=CNY

# Stripe 配置
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# 税务配置
TAX_DEFAULT_REGION=CN
TAX_ENABLED=true

# 超级管理员角色（逗号分隔）
SUPER_ADMIN_ROLES=admin,super_admin

# 使用量缓冲配置（高并发场景）
# 开启后使用量记录先写入 Redis，再由定时任务批量写入数据库
USAGE_BUFFER_ENABLED=false
USAGE_BUFFER_BATCH_SIZE=1000
USAGE_BUFFER_FLUSH_INTERVAL=60
